{
  "name": "letsencrypt-dns-tool",
  "version": "1.1.0",
  "description": "Let's Encrypt certificate tool with manual DNS verification, now with multi-platform KV and edge function support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "node esbuild.config.js",
    "build:esa": "esbuild server.js --platform=node --target=node16 --format=cjs --bundle --external:crypto --external:fs --external:path --external:events --external:net --external:util --outfile=dist/index.js",
    "clean": "rm -rf dist node_modules",
    "lint": "eslint server.js"
  },
  "dependencies": {
    "acme-client": "^5.4.0",
    "express": "^4.21.0",
    "node-forge": "^1.3.1",
    "serverless-http": "^3.2.0"
  },
  "optionalDependencies": {
    "@alicloud/esa-kv-sdk": "^1.0.0",
    "@octokit/rest": "^21.0.0",
    "tencentcloud-sdk-nodejs-teo": "^4.0.1000"
  },
  "devDependencies": {
    "esbuild": "^0.23.1",
    "eslint": "^10.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "letsencrypt",
    "acme",
    "ssl",
    "certificate",
    "dns-01",
    "edge-function",
    "aliyun-esa",
    "cloudflare-workers",
    "tencent-edgeone"
  ],
  "author": "",
  "license": "MIT",
  "volta": {
    "node": "16.20.2"
  },
  "esa": {
    "build": {
      "command": "npm install && npm run build:esa",
      "outputDir": "dist",
      "entryFile": "index.js"
    }
  }
}