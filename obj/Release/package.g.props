<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PackageJsonName Condition="$(PackageJsonName) == ''">letsencrypt-dns-tool</PackageJsonName>
    <PackageJsonVersion Condition="$(PackageJsonVersion) == ''">1.1.0</PackageJsonVersion>
    <PackageJsonDescription Condition="$(PackageJsonDescription) == ''">Let's Encrypt certificate tool with manual DNS verification, now with multi-platform KV and edge function support</PackageJsonDescription>
    <PackageJsonMain Condition="$(PackageJsonMain) == ''">server.js</PackageJsonMain>
    <PackageJsonScriptsStart Condition="$(PackageJsonScriptsStart) == ''">node server.js</PackageJsonScriptsStart>
    <PackageJsonScriptsDev Condition="$(PackageJsonScriptsDev) == ''">node server.js</PackageJsonScriptsDev>
    <PackageJsonScriptsBuild Condition="$(PackageJsonScriptsBuild) == ''">echo 'No build required for Node.js server'</PackageJsonScriptsBuild>
    <PackageJsonDependenciesExpress Condition="$(PackageJsonDependenciesExpress) == ''">^4.21.0</PackageJsonDependenciesExpress>
    <PackageJsonDependenciesAcmeClient Condition="$(PackageJsonDependenciesAcmeClient) == ''">^5.4.0</PackageJsonDependenciesAcmeClient>
    <PackageJsonDependenciesNodeForge Condition="$(PackageJsonDependenciesNodeForge) == ''">^1.3.1</PackageJsonDependenciesNodeForge>
    <PackageJsonDependenciesServerlessHttp Condition="$(PackageJsonDependenciesServerlessHttp) == ''">^3.2.0</PackageJsonDependenciesServerlessHttp>
    <PackageJsonOptionaldependenciesTencentcloudSdkNodejsTeo Condition="$(PackageJsonOptionaldependenciesTencentcloudSdkNodejsTeo) == ''">^4.0.1000</PackageJsonOptionaldependenciesTencentcloudSdkNodejsTeo>
    <PackageJsonOptionaldependenciesAlicloudEsaKvSdk Condition="$(PackageJsonOptionaldependenciesAlicloudEsaKvSdk) == ''">^1.0.0</PackageJsonOptionaldependenciesAlicloudEsaKvSdk>
    <PackageJsonOptionaldependenciesOctokitRest Condition="$(PackageJsonOptionaldependenciesOctokitRest) == ''">^21.0.0</PackageJsonOptionaldependenciesOctokitRest>
    <PackageJsonEnginesNode Condition="$(PackageJsonEnginesNode) == ''">&gt;=16.0.0</PackageJsonEnginesNode>
  </PropertyGroup>
</Project>